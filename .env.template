# =============================================================================
# .env.template — Variables d'environnement du projet Reporting démo
# =============================================================================
#
# UTILISATION :
#   1. Copier ce fichier : cp .env.template .env
#   2. Renseigner les valeurs selon ton environnement
#   3. Ne jamais versionner le .env (il est dans .gitignore)
#
# FORMAT :
#   - Lignes commençant par # : commentaires (ignorés)
#   - Lignes vides : ignorées
#   - Valeurs sans guillemets (python-dotenv les retire automatiquement)
#
# CHARGEMENT :
#   Automatique au démarrage via `from dotenv import load_dotenv` dans config.py.
#   Si python-dotenv n'est pas installé, les valeurs par défaut s'appliquent.
# =============================================================================


# -----------------------------------------------------------------------------
# CHEMINS
# -----------------------------------------------------------------------------

# Répertoire contenant les fichiers Excel sources (mode Batch).
# Valeur par défaut : "data"  (relatif à la racine du projet)
# Exemple production : DATA_DIR=C:\Exports\Ventes\2025
# Exemple serveur    : DATA_DIR=/mnt/partage/exports_crm
DATA_DIR=data

# Répertoire de sortie pour les fichiers générés (Excel, PDF, logs).
# Valeur par défaut : "output"
# Exemple production : OUTPUT_DIR=C:\Reporting\Resultats
OUTPUT_DIR=output


# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------

# Niveau de verbosité des logs Python.
# Valeurs acceptées : DEBUG | INFO | WARNING | ERROR | CRITICAL
# - DEBUG   : tout afficher (développement / diagnostic)
# - INFO    : messages de suivi normaux (recommandé en production)
# - WARNING : uniquement les anomalies non bloquantes
# - ERROR   : uniquement les erreurs
LOG_LEVEL=INFO


# -----------------------------------------------------------------------------
# RÉCONCILIATION DES DONNEES
# -----------------------------------------------------------------------------

# Tolérance maximale acceptée pour l'écart entre la somme source et la somme
# traitée, exprimée en proportion (pas en pourcentage).
#
# Justification : les opérations sur flottants IEEE 754 introduisent des
# micro-écarts inévitables (ex: 0.1 + 0.2 ≠ 0.3 exactement en binaire).
# La valeur par défaut de 0.001 (= 0.1 %) absorbe ces imperfections sans
# masquer une vraie perte de données.
#
# ⚠️  Ne pas dépasser 0.01 (1 %) sans justification écrite dans le log d'audit.
# Valeur par défaut : 0.001
RECON_TOLERANCE_PCT=0.001


